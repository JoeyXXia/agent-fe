# 复制为 .env 后按需修改，然后重启 `npm run dev`
#   bash:  cp .env.example .env
#   Windows cmd:  copy .env.example .env
#   PowerShell:     Copy-Item .env.example .env

# 后端 API：开发环境一般不用改，默认走 Vite 代理（/api → localhost:3001）
VITE_API_URL=/api

# Agent 是否用服务端 LLM：
# - 不写本变量，或设为 true：会请求 /api/agent/chat（需已登录且 server 配置 AI 密钥）
# - 设为 false：仅用浏览器内 ReAct + 工具链（适合演示脚手架、多文件预览）
VITE_AGENT_USE_LLM=false

# MCP 扩展工具列表由服务端 GET /api/mcp/tools 提供（需登录）；配置见 server/.env.example 中 MCP_*
