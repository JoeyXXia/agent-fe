PORT=3001
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-to-a-random-string

# Agent 工作台 `POST /api/agent/chat` 与智能笔记共用下方 AI_* 与备用链；未配置时前端会回退本地 ReAct
# 单次上游 LLM 等待上限（毫秒），防止 Node fetch 永久挂起；默认 180000
# AI_AGENT_TIMEOUT_MS=180000

# ---------- 主 LLM（OpenAI 兼容：OpenAI / DeepSeek / Ollama 等）----------
# 不填 AI_API_KEY 则笔记 AI 走本地 Mock
AI_API_KEY=
# 根路径须以 /v1 结尾（代码会再拼 /chat/completions）
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# ---------- 备用 1：OpenAI 官方或其它兼容端（主通道失败时按序尝试）----------
AI_OPENAI_BACKUP_API_KEY=
AI_OPENAI_BACKUP_BASE_URL=https://api.openai.com/v1
AI_OPENAI_BACKUP_MODEL=gpt-4o-mini

# ---------- 备用 2：Anthropic Claude（Messages API，主通道与备用 1 均失败时尝试）----------
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---------- 备用 3：本地 Ollama（OpenAI 兼容，链尾最后尝试；需本机 ollama serve + ollama pull）----------
# 设为 1 / true 即启用；或只填 AI_OLLAMA_BACKUP_BASE_URL（自定义地址时）
AI_OLLAMA_BACKUP=
# AI_OLLAMA_BACKUP_BASE_URL=http://127.0.0.1:11434/v1
# Docker/WSL 访问宿主机 Ollama 时可改为 http://host.docker.internal:11434/v1
# AI_OLLAMA_BACKUP_MODEL=llama3.2
# AI_OLLAMA_BACKUP_API_KEY=ollama-local

# ---------- MCP（Model Context Protocol，服务端 Client）----------
# 参见仓库 ai项目扩展/MCP-INTEGRATION.md。未配置时 GET /api/mcp/tools 返回 configured:false，不视为错误。
# 传输：stdio（子进程，默认）或 http（Streamable HTTP）
# MCP_TRANSPORT=stdio

# stdio：可执行文件 + 参数（JSON 数组）
# MCP_STDIO_COMMAND=npx
# MCP_STDIO_ARGS=["-y","@modelcontextprotocol/server-everything"]
# 可选：子进程额外环境、工作目录（JSON 对象）
# MCP_STDIO_ENV_JSON={}
# MCP_STDIO_CWD=

# HTTP：远端 MCP 的 Streamable HTTP 根 URL
# MCP_TRANSPORT=http
# MCP_HTTP_URL=https://example.com/mcp
# MCP_HTTP_HEADERS_JSON={"Authorization":"Bearer your-token"}

# MCP_CONNECT_TIMEOUT_MS=15000
# MCP_CALL_TIMEOUT_MS=60000
# MCP_ARG_MAX_CHARS=65536
# 默认禁止 file:// 资源；仅在内网/sandbox 中按需开启
# MCP_ALLOW_FILE_URIS=

# ---------- RAG（笔记向量检索，Agent /chat 前注入上下文）----------
# 使用 OpenAI 兼容 POST /v1/embeddings；未单独配置时复用 AI_API_KEY + AI_BASE_URL
# AI_EMBEDDING_API_KEY=
# AI_EMBEDDING_BASE_URL=
# AI_EMBEDDING_MODEL=text-embedding-3-small
# RAG_TOP_K=6
# RAG_MIN_SIMILARITY=0.22
# 设为 1 / true 关闭 RAG（不请求 embedding，与文档「降级」一致）
# RAG_DISABLED=
