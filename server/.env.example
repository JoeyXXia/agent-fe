PORT=3001
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-to-a-random-string

# ---------- 主 LLM（OpenAI 兼容：OpenAI / DeepSeek / Ollama 等）----------
# 不填 AI_API_KEY 则笔记 AI 走本地 Mock
AI_API_KEY=
# 根路径须以 /v1 结尾（代码会再拼 /chat/completions）
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# ---------- 备用 1：OpenAI 官方或其它兼容端（主通道失败时按序尝试）----------
AI_OPENAI_BACKUP_API_KEY=
AI_OPENAI_BACKUP_BASE_URL=https://api.openai.com/v1
AI_OPENAI_BACKUP_MODEL=gpt-4o-mini

# ---------- 备用 2：Anthropic Claude（Messages API，主通道与备用 1 均失败时尝试）----------
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---------- 备用 3：本地 Ollama（OpenAI 兼容，链尾最后尝试；需本机 ollama serve + ollama pull）----------
# 设为 1 / true 即启用；或只填 AI_OLLAMA_BACKUP_BASE_URL（自定义地址时）
AI_OLLAMA_BACKUP=
# AI_OLLAMA_BACKUP_BASE_URL=http://127.0.0.1:11434/v1
# Docker/WSL 访问宿主机 Ollama 时可改为 http://host.docker.internal:11434/v1
# AI_OLLAMA_BACKUP_MODEL=llama3.2
# AI_OLLAMA_BACKUP_API_KEY=ollama-local
